use std::console as Console;
use std::algorithms as Algorithms;
use std::math as Math;

fn Entry() -> i32
{
    mut strs: string[] = [];
    strs.Push("Foo");
    strs.Push("Bar");
    strs.Push("Baz");

    mut str: string = strs.Join(",");
    str.Push(']');
    str = str.Reversed();
    str.Push('[');

    Console::PrintLine(str.Reversed());
}