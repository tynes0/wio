        @Native @CppName(wio::runtime::std_math::IsEvenU64) fn IsEven(value: u64) -> bool;

        fn IsEven(value: isize) -> bool {
            return (value % (2 fit isize)) == (0 fit isize);
        }

        fn IsEven(value: usize) -> bool {
            return (value % 2usize) == 0usize;
        }

