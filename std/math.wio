realm std {
    realm math {
        use @CppHeader("std_math.h");

        const Pi: f64 = 3.141592653589793;
        const Tau: f64 = 6.283185307179586;
        const HalfPi: f64 = 1.5707963267948966;
        const E: f64 = 2.718281828459045;
        const Sqrt2: f64 = 1.4142135623730951;
        const Ln2: f64 = 0.6931471805599453;
        const Ln10: f64 = 2.302585092994046;
        const DegToRadFactor: f64 = Pi / 180.0;
        const RadToDegFactor: f64 = 180.0 / Pi;

        const Pi32: f32 = Pi fit f32;
        const Tau32: f32 = Tau fit f32;
        const HalfPi32: f32 = HalfPi fit f32;
        const E32: f32 = E fit f32;
        const Sqrt232: f32 = Sqrt2 fit f32;
        const Ln232: f32 = Ln2 fit f32;
        const Ln1032: f32 = Ln10 fit f32;

        @Native @CppName(wio::runtime::std_math::AbsI8) fn Abs(value: i8) -> i8;
        @Native @CppName(wio::runtime::std_math::AbsI16) fn Abs(value: i16) -> i16;
        @Native @CppName(wio::runtime::std_math::AbsI32) fn Abs(value: i32) -> i32;
        @Native @CppName(wio::runtime::std_math::AbsI64) fn Abs(value: i64) -> i64;
        @Native @CppName(wio::runtime::std_math::AbsF32) fn Abs(value: f32) -> f32;
        @Native @CppName(wio::runtime::std_math::AbsF64) fn Abs(value: f64) -> f64;

        fn Abs(value: isize) -> isize {
            if (value < (0 fit isize)) {
                return -value;
            }
            return value;
        }

        fn Abs(value: usize) -> usize {
            return value;
        }

        @Native @CppName(wio::runtime::std_math::SaturatingAbsI8) fn SaturatingAbs(value: i8) -> i8;
        @Native @CppName(wio::runtime::std_math::SaturatingAbsI16) fn SaturatingAbs(value: i16) -> i16;
        @Native @CppName(wio::runtime::std_math::SaturatingAbsI32) fn SaturatingAbs(value: i32) -> i32;
        @Native @CppName(wio::runtime::std_math::SaturatingAbsI64) fn SaturatingAbs(value: i64) -> i64;

        @Native @CppName(wio::runtime::std_math::MinI8) fn Min(left: i8, right: i8) -> i8;
        @Native @CppName(wio::runtime::std_math::MinI16) fn Min(left: i16, right: i16) -> i16;
        @Native @CppName(wio::runtime::std_math::MinI32) fn Min(left: i32, right: i32) -> i32;
        @Native @CppName(wio::runtime::std_math::MinI64) fn Min(left: i64, right: i64) -> i64;
        @Native @CppName(wio::runtime::std_math::MinU8) fn Min(left: u8, right: u8) -> u8;
        @Native @CppName(wio::runtime::std_math::MinU16) fn Min(left: u16, right: u16) -> u16;
        @Native @CppName(wio::runtime::std_math::MinU32) fn Min(left: u32, right: u32) -> u32;
        @Native @CppName(wio::runtime::std_math::MinU64) fn Min(left: u64, right: u64) -> u64;
        @Native @CppName(wio::runtime::std_math::MinF32) fn Min(left: f32, right: f32) -> f32;
        @Native @CppName(wio::runtime::std_math::MinF64) fn Min(left: f64, right: f64) -> f64;

        fn Min(left: isize, right: isize) -> isize {
            if (left < right) {
                return left;
            }
            return right;
        }

        fn Min(left: usize, right: usize) -> usize {
            if (left < right) {
                return left;
            }
            return right;
        }

        @Native @CppName(wio::runtime::std_math::MaxI8) fn Max(left: i8, right: i8) -> i8;
        @Native @CppName(wio::runtime::std_math::MaxI16) fn Max(left: i16, right: i16) -> i16;
        @Native @CppName(wio::runtime::std_math::MaxI32) fn Max(left: i32, right: i32) -> i32;
        @Native @CppName(wio::runtime::std_math::MaxI64) fn Max(left: i64, right: i64) -> i64;
        @Native @CppName(wio::runtime::std_math::MaxU8) fn Max(left: u8, right: u8) -> u8;
        @Native @CppName(wio::runtime::std_math::MaxU16) fn Max(left: u16, right: u16) -> u16;
        @Native @CppName(wio::runtime::std_math::MaxU32) fn Max(left: u32, right: u32) -> u32;
        @Native @CppName(wio::runtime::std_math::MaxU64) fn Max(left: u64, right: u64) -> u64;
        @Native @CppName(wio::runtime::std_math::MaxF32) fn Max(left: f32, right: f32) -> f32;
        @Native @CppName(wio::runtime::std_math::MaxF64) fn Max(left: f64, right: f64) -> f64;

        fn Max(left: isize, right: isize) -> isize {
            if (left < right) {
                return right;
            }
            return left;
        }

        fn Max(left: usize, right: usize) -> usize {
            if (left < right) {
                return right;
            }
            return left;
        }

        @Native @CppName(wio::runtime::std_math::ClampI8) fn Clamp(value: i8, minValue: i8, maxValue: i8) -> i8;
        @Native @CppName(wio::runtime::std_math::ClampI16) fn Clamp(value: i16, minValue: i16, maxValue: i16) -> i16;
        @Native @CppName(wio::runtime::std_math::ClampI32) fn Clamp(value: i32, minValue: i32, maxValue: i32) -> i32;
        @Native @CppName(wio::runtime::std_math::ClampI64) fn Clamp(value: i64, minValue: i64, maxValue: i64) -> i64;
        @Native @CppName(wio::runtime::std_math::ClampU8) fn Clamp(value: u8, minValue: u8, maxValue: u8) -> u8;
        @Native @CppName(wio::runtime::std_math::ClampU16) fn Clamp(value: u16, minValue: u16, maxValue: u16) -> u16;
        @Native @CppName(wio::runtime::std_math::ClampU32) fn Clamp(value: u32, minValue: u32, maxValue: u32) -> u32;
        @Native @CppName(wio::runtime::std_math::ClampU64) fn Clamp(value: u64, minValue: u64, maxValue: u64) -> u64;
        @Native @CppName(wio::runtime::std_math::ClampF32) fn Clamp(value: f32, minValue: f32, maxValue: f32) -> f32;
        @Native @CppName(wio::runtime::std_math::ClampF64) fn Clamp(value: f64, minValue: f64, maxValue: f64) -> f64;

        fn Clamp(value: isize, minValue: isize, maxValue: isize) -> isize {
            let low = Min(minValue, maxValue);
            let high = Max(minValue, maxValue);
            if (value < low) {
                return low;
            }
            if (value > high) {
                return high;
            }
            return value;
        }

        fn Clamp(value: usize, minValue: usize, maxValue: usize) -> usize {
            let low = Min(minValue, maxValue);
            let high = Max(minValue, maxValue);
            if (value < low) {
                return low;
            }
            if (value > high) {
                return high;
            }
            return value;
        }

        @Native @CppName(wio::runtime::std_math::SaturateF32) fn Saturate(value: f32) -> f32;
        @Native @CppName(wio::runtime::std_math::SaturateF64) fn Saturate(value: f64) -> f64;

        fn Clamp01(value: f32) -> f32 {
            return Saturate(value);
        }

        fn Clamp01(value: f64) -> f64 {
            return Saturate(value);
        }

        @Native @CppName(wio::runtime::std_math::SignI8) fn Sign(value: i8) -> i8;
        @Native @CppName(wio::runtime::std_math::SignI16) fn Sign(value: i16) -> i16;
        @Native @CppName(wio::runtime::std_math::SignI32) fn Sign(value: i32) -> i32;
        @Native @CppName(wio::runtime::std_math::SignI64) fn Sign(value: i64) -> i64;
        @Native @CppName(wio::runtime::std_math::SignU8) fn Sign(value: u8) -> u8;
        @Native @CppName(wio::runtime::std_math::SignU16) fn Sign(value: u16) -> u16;
        @Native @CppName(wio::runtime::std_math::SignU32) fn Sign(value: u32) -> u32;
        @Native @CppName(wio::runtime::std_math::SignU64) fn Sign(value: u64) -> u64;
        @Native @CppName(wio::runtime::std_math::SignF32) fn Sign(value: f32) -> f32;
        @Native @CppName(wio::runtime::std_math::SignF64) fn Sign(value: f64) -> f64;

        fn Sign(value: isize) -> isize {
            if (value > (0 fit isize)) {
                return 1 fit isize;
            }
            if (value < (0 fit isize)) {
                return -1 fit isize;
            }
            return 0 fit isize;
        }

        fn Sign(value: usize) -> usize {
            if (value == 0usize) {
                return 0usize;
            }
            return 1usize;
        }

        @Native @CppName(wio::runtime::std_math::SignNonZeroF32) fn SignNonZero(value: f32) -> f32;
        @Native @CppName(wio::runtime::std_math::SignNonZeroF64) fn SignNonZero(value: f64) -> f64;

        fn Square<T>(value: T) -> T {
            return value * value;
        }

        fn Cube<T>(value: T) -> T {
            return value * value * value;
        }

        fn InRangeInclusive<T>(value: T, minValue: T, maxValue: T) -> bool {
            if (minValue <= maxValue) {
                return value >= minValue and value <= maxValue;
            }
            return value >= maxValue and value <= minValue;
        }

        fn InRangeExclusive<T>(value: T, minValue: T, maxValue: T) -> bool {
            if (minValue <= maxValue) {
                return value > minValue and value < maxValue;
            }
            return value > maxValue and value < minValue;
        }

        @Native @CppName(wio::runtime::std_math::IsNanF32) fn IsNan(value: f32) -> bool;
        @Native @CppName(wio::runtime::std_math::IsNanF64) fn IsNan(value: f64) -> bool;
        @Native @CppName(wio::runtime::std_math::IsInfF32) fn IsInf(value: f32) -> bool;
        @Native @CppName(wio::runtime::std_math::IsInfF64) fn IsInf(value: f64) -> bool;
        @Native @CppName(wio::runtime::std_math::IsFiniteF32) fn IsFinite(value: f32) -> bool;
        @Native @CppName(wio::runtime::std_math::IsFiniteF64) fn IsFinite(value: f64) -> bool;
        @Native @CppName(wio::runtime::std_math::IsNormalF32) fn IsNormal(value: f32) -> bool;
        @Native @CppName(wio::runtime::std_math::IsNormalF64) fn IsNormal(value: f64) -> bool;
        @Native @CppName(wio::runtime::std_math::SignBitF32) fn SignBit(value: f32) -> bool;
        @Native @CppName(wio::runtime::std_math::SignBitF64) fn SignBit(value: f64) -> bool;

        @Native @CppName(wio::runtime::std_math::ApproxEqF32) fn ApproxEq(value: f32, other: f32, epsilon: f32) -> bool;
        @Native @CppName(wio::runtime::std_math::ApproxEqF64) fn ApproxEq(value: f64, other: f64, epsilon: f64) -> bool;

        fn ApproxEq(value: f32, other: f32) -> bool {
            return ApproxEq(value, other, 0.00001f);
        }

        fn ApproxEq(value: f64, other: f64) -> bool {
            return ApproxEq(value, other, 0.0000001);
        }

        @Native @CppName(wio::runtime::std_math::ApproxZeroF32) fn ApproxZero(value: f32) -> bool;
        @Native @CppName(wio::runtime::std_math::ApproxZeroF64) fn ApproxZero(value: f64) -> bool;
