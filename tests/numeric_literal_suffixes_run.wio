use std::console;

fn Entry() -> i32 {
    let count: usize = 0x10usize;
    let offset: isize = 0b11isize;
    let precise32: f32 = 1.5f32;
    let precise64: f64 = 2.5f64;

    std::console::Print($"Numeric literal suffixes: ${count}/${offset}/${precise32 > 1.0f32}/${precise64 > 2.0f64}");
    return 0;
}
