use std::io;

enum DamageType {
    Physical = 0,
    Magical = 1,
    TrueDamage = 2
}

flagset StatusEffects {
    None = 0,
    Poisoned = 1,
    Burning = 2,
    Stunned = 4
}

fn LogHealth(hp: i32) when (hp >= 0) {
    std::io::Print($"Current hp: ${hp}\n");
}

// Secured bypass
fn CalculateMultiplier(level: i32, is_vip: bool) -> f32 when (level in 1...100) else 1.0f {
    let base_multi = match (level) {
        1..<10: 1.0f; // 1-9 
        10...49: 1.5f; // 10-49 
        50...99 or 100: 2.0f; // 50-99 or 100
        assumed: 1.0f;
    };
    if (is_vip)
        return base_multi * 1.5f;
    return base_multi;
}

fn ApplyFilter(val: i32, filter_fn: fn(i32) -> i32) -> i32 {
    return filter_fn(val);
}

fn Entry() -> i32 {
    std::io::Print("=== WIO TEST ===\n\n");
    let double_damage = (dmg: i32) => dmg * 2; // Semantic Analyzer will automatically detect the return type
    let block_lambda: fn(i32) -> i32 = (dmg: i32) => { // We write the return value ourselves
        std::io::Print($"[System] Block lambda is being processed: ${dmg}\n");
        return dmg + 10;
    };

    let final_dmg1 = ApplyFilter(25, double_damage);
    let final_dmg2 = ApplyFilter(25, block_lambda);
    let final_dmg3 = ApplyFilter(25, (x: i32) => x * 3);

    std::io::Print($"Final Dmg 1 (x2)  : ${final_dmg1}\n");
    std::io::Print($"Final Dmg 2 (+10) : ${final_dmg2}\n");
    std::io::Print($"Final Dmg 3 (x3)  : ${final_dmg3}\n");

    let multi_vip = CalculateMultiplier(55, true);
    let multi_invalid = CalculateMultiplier(999, false);
    
    std::io::Print($"55 Level VIP Multiplier: ${multi_vip}\n");
    std::io::Print($"999 Level (Guard) Multiplier: ${multi_invalid}\n");

    // Only 100 is displayed on the screen, -50 is not.
    LogHealth(100);
    LogHealth(-50);

    mut my_status = StatusEffects::Poisoned | StatusEffects::Burning;
    if ((my_status & StatusEffects::Burning) == StatusEffects::Burning) {
        std::io::Print("Fire!\n");
    }
}