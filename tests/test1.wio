use std::io;

// ==========================================
// 1. FORWARD DECLARATION TESTİ (Entry En Üstte!)
// ==========================================
fn Entry() -> i32 {
    
    std::io::Print("=== WIO MOTORU: OOP VE ECS TESTI BASLIYOR ===\n");

    // --- COMPONENT TESTLERİ ---
    mut pos1 = Transform(); 
    mut pos2 = Transform(10.5, 20.0, 5.0); 
    
    // Wio'nun kendi String Interpolation'ı çalışıyor! (Arkada C++ std::format'a dönecek)
    std::io::Print($"Transform 2'nin X degeri: ${pos2.x}\n");
    
    pos1.x = 100.0;
    pos1.Describe(); 

    // --- OBJECT TESTLERİ ---
    mut hero = Player("Arthur", 100);
    hero.Describe();
    
    hero.TakeDamage(25);
    std::io::Print($"Guncel Can (Disaridan Okuma): ${hero.health}\n"); 

    mut heroClone = Player(ref hero);
    std::io::Print("--- Klon Olusturuldu ---\n");
    heroClone.Describe();

    std::io::Print("=== TUM TESTLER BASARILI! ===\n");
    return 0;
}

// ==========================================
// 2. ARAYÜZLER (Sözleşmeler)
// ==========================================
interface IDescribable {
    fn Describe();
}

interface IDamageable {
    fn TakeDamage(amount: i32);
}

// ==========================================
// 3. COMPONENT (Saf Veri ve Yaşam Döngüsü)
// ==========================================
@From(IDescribable)
component Transform {
    x: f32 = 0.0f32;
    y: f32 = 0.0f32;
    z: f32 = 0.0f32;
    
    OnConstruct()
    {
    }
    
    OnConstruct(_x: f32, _y: f32, _z: f32)
    {
        x = _x;
        y = _y;
        z = _z;
    }

    fn Describe() {
        std::io::Print($"Transform Durumu: X=${x}, Y=${y}, Z=${z}\n");
    }
}

// ==========================================
// 4. OBJECT (Mantık ve Gizlilik)
// ==========================================
@From(IDescribable, IDamageable)
@Default(private) 
object Player {
    
    public name: string;
    
    @Readonly
    public health: i32; 
    
    secretKey: i32 = 42; 

    public OnConstruct(playerName: string, startHealth: i32) {
        name = playerName;
        health = startHealth;
        std::io::Print($"Player [${name}] oyuna katildi!\n");
    }

    public OnConstruct(other: view Player) {
        name = $"${other.name} (Klonu)";
        health = other.health;
    }       

    public fn Describe() {
        std::io::Print($"Benim adim ${name}, canim ${health} ve gizli anahtarim ${secretKey}.\n");
    }

    public fn TakeDamage(amount: i32) {
        health = health - amount; 
        std::io::Print($"${name} adli oyuncu ${amount} hasar aldi!\n");
    }
}