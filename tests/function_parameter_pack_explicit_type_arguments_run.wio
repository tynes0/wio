use std::assert as assert;
use std::console as console;

realm ffi {
    @Native
    @CppHeader("native_pack_ops.h")
    @CppName(native_pack::CountTypes)
    fn CountTypes<Args...>(args: Args...) -> i32;

    @Native
    @CppHeader("native_pack_ops.h")
    @CppName(native_pack::CountWithHead)
    fn CountWithHead<T, Args...>(head: T, tail: Args...) -> i32;
}

fn ForwardTyped<T, Args...>(head: T, tail: Args...) -> i32 {
    return ffi::CountWithHead<T, Args...>(head, tail...);
}

fn Entry() -> i32 {
    let direct = ffi::CountTypes<i32, bool>(1i32, true);
    let forwarded = ForwardTyped<i32, i16, i8>(7i32, 8i16, 9i8);

    assert::ExpectEqual(direct, 2, "explicit parameter-pack type arguments failed");
    assert::ExpectEqual(forwarded, 3, "symbolic explicit parameter-pack forwarding failed");

    console::Print("Function packs explicit args: ok");
    return 0;
}
