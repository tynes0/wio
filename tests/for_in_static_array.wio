use std::console as console;

fn Entry() -> i32 {
    let values: [i32; 5] = [1, 2, 3, 4, 5];
    mut sum: i32 = 0;

    for (mut value in values) {
        if (value == 4) {
            break;
        }

        value += 1;
        sum += value;
    }

    console::Print($"For in static sum: ${sum}");
    return 0;
}
