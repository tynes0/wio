use std::io as console;

object Box<T> {
    public value: T;

    OnConstruct(value: T) {
        self.value = value;
    }

    public fn Get() -> T {
        return self.value;
    }
}

fn Entry() -> i32 {
    let numberBox = Box(7);
    let textBox = Box("wio");
    console::Print($"Generic ctor deduction: ${numberBox.Get()}, ${textBox.Get()}");
    return 0;
}
