// ==========================
// Components (DATA ONLY)
// ==========================

component Transform {
    position: vec2;
    rotation: f32;
}

component Velocity {
    value: vec2;
}

component Lifetime {
    time: f32;
}


// ==========================
// Objects (STATE + METHODS)
// ==========================

object Player {

    transform: Transform;
    velocity: Velocity;
    health: i32;

    fn move(dir: vec2) {
        self.velocity.value = dir * 5.0;
    }

    fn damage(amount: i32) {
        self.health -= amount;
        if self.health <= 0 {
            destroy(self);
        }
    }
}

object Bomb {

    transform: Transform;
    lifetime: Lifetime;

    fn explode() {
        spawn Explosion at self.transform.position;
        destroy(self);
    }
}

object Explosion {
    transform: Transform;
}


// ==========================
// Systems (PROGRAM-LEVEL)
// ==========================

system Movement runs_each frame {

    for obj with Transform, Velocity {
        obj.transform.position += obj.velocity.value * frame.delta;
    }
}

system LifetimeSystem runs_each frame {

    for obj with Lifetime {
        obj.lifetime.time -= frame.delta;

        if obj.lifetime.time <= 0 {
            if obj has fn explode {
                obj.explode();
            } else {
                destroy(obj);
            }
        }
    }
}


// ==========================
// Coroutines
// ==========================

// coroutine fn explode_later(bomb: Bomb) {
//     wait 2s;
//     bomb.explode();
// }


// ==========================
// Program
// ==========================

program running window.is_open() {

    init {
        window.create(1280, 720, "WIO Engine");

        program.add_system(Movement);
        program.add_system(LifetimeSystem);

        let player = spawn Player {
            transform = { position = vec2(0, 0), rotation = 0 },
            velocity  = { value = vec2(0, 0) },
            health    = 100
        };
    }

    frame {
        input.update();

        if input.key_pressed(Key.W) {
            player.move(vec2(0, 1));
        }

        if input.key_pressed(Key.Space) {
            let bomb = spawn Bomb {
                transform = { position = player.transform.position },
                lifetime  = { time = 3.0 }
            };

            explode_later(bomb);
        }

        renderer.begin();
        renderer.draw_world();
        renderer.end();
    }

    shutdown {
        save_game();
        window.close();
    }
}
