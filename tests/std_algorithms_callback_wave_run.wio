use std::algorithms as algorithms;
use std::console as console;

fn Entry() -> i32 {
    let values: i32[] = [1, 2, 3, 4, 5, 6];

    let isEven: fn(i32) -> bool = (value) => value % 2 == 0;
    let doubleValue: fn(i32) -> i32 = (value) => value * 2;
    let sumReducer: fn(i32, i32) -> i32 = (acc, value) => {
        return acc + value;
    };

    let evens = algorithms::Filter(values, isEven);
    let doubled = algorithms::Map(values, doubleValue);
    let evenCount: i32 = algorithms::CountBy(values, isEven) fit i32;
    let sum = algorithms::Reduce(values, 0, sumReducer);
    let grouped = algorithms::GroupCountBy(values, (value: i32) => value % 3);

    let groupZero: i32 = grouped.GetOr(0, 0 fit usize) fit i32;
    let groupOne: i32 = grouped.GetOr(1, 0 fit usize) fit i32;
    let groupTwo: i32 = grouped.GetOr(2, 0 fit usize) fit i32;

    console::Print($"Callback wave: ${evens.Count() fit i32}/${evens.First()}/${evens.Last()}/${doubled.First()}/${doubled.Last()}/${evenCount}/${sum}/${groupZero}/${groupOne}/${groupTwo}");
    return 0;
}
