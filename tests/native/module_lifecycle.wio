mut gCounter: i32 = 0;

@ModuleApiVersion
fn RuntimeAbi() -> u32 {
    return 1;
}

@ModuleLoad
fn BootModule() -> i32 {
    gCounter = 40;
    return 0;
}

@ModuleUpdate
fn TickModule(deltaTime: f32) {
    gCounter += deltaTime fit i32;
}

@ModuleUnload
fn StopModule() {
    gCounter = -1;
}

@Export
@CppName(WioGetCounter)
fn GetCounter() -> i32 {
    return gCounter;
}

@Export
@CppName(WioAddToCounter)
fn AddToCounter(delta: i32) -> i32 {
    gCounter += delta;
    return gCounter;
}
