mut gCounter: i32 = 0;

@ModuleApiVersion
fn RuntimeAbi() -> u32 {
    return 1;
}

@ModuleLoad
fn BootModule() -> i32 {
    gCounter = 40;
    return 0;
}

@ModuleUpdate
fn TickModule(deltaTime: f32) {
    gCounter += deltaTime fit i32;
}

@ModuleSaveState
fn SaveState() -> i32 {
    return gCounter;
}

@ModuleRestoreState
fn RestoreState(snapshot: i32) -> i32 {
    gCounter = snapshot;
    return 0;
}

@ModuleUnload
fn StopModule() {
}

@Export
@CppName(WioGetCounter)
fn GetCounter() -> i32 {
    return gCounter;
}
