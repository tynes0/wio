use std::io as console;

object Box<T> {
    OnConstruct() {
    }

    public fn Echo(value: T) -> T {
        return value;
    }
}

fn MakeBox() -> Box<i32> {
    return Box();
}

fn Entry() -> i32 {
    let box: Box<i32> = Box();
    mut assigned: Box<i32> = MakeBox();
    assigned = Box();
    let made = MakeBox();

    console::Print($"Generic ctor expected type: ${box.Echo(7)}, ${assigned.Echo(9)}, ${made.Echo(11)}");
    return 0;
}
