use std::assert as assert;
use std::console as console;

object MutablePackBox<Args...> {
    public pack values: Args...;

    OnConstruct(args: Args...) {
        self.values = args.array;
    }

    public fn SetFirst(value: Args[0usize]) {
        self.values[0usize] = value;
    }

    public fn SetLast(value: Args[Args.size - 1usize]) {
        self.values[self.values.size - 1usize] = value;
    }

    public fn First() -> Args[0usize] {
        return self.values[0usize];
    }

    public fn Last() -> Args[Args.size - 1usize] {
        return self.values[self.values.size - 1usize];
    }
}

fn Entry() -> i32 {
    let box: MutablePackBox<i32, i32, i32> = MutablePackBox(1i32, 2i32, 3i32);

    box.values[1usize] = 20i32;
    box.SetFirst(10i32);
    box.SetLast(30i32);

    let typedValues = box.values.ToStaticArray<i32>();

    assert::ExpectEqual(box.First(), 10, "pack storage first write failed");
    assert::ExpectEqual(typedValues[1usize], 20, "pack storage indexed write failed");
    assert::ExpectEqual(box.Last(), 30, "pack storage last write failed");

    console::Print("Pack storage write semantics: ok");
    return 0;
}
