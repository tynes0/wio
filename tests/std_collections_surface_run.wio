use std::collections as collections;
use std::console as console;

fn Entry() -> i32 {
    let values: collections::Array<i32> = [3, 1, 4];
    let hasFour = collections::Contains(values, 4);
    let first = collections::FirstOr(values, -1);
    let staged = collections::Inserted(collections::Pushed(values, 2), 1 fit usize, 9);
    let slice = collections::Slice(staged, 1 fit usize, 2 fit usize);
    let extended = collections::Extended(staged, [8, 7]);
    let filled = collections::Filled([1, 2, 3], 5);
    let sorted = collections::Sorted(values);
    let joined = collections::Join(["a", "b", "c"], ":");

    let scores: collections::Dictionary<string, i32> = {
        "hp": 7,
        "mana": 3
    };

    let updatedScores = collections::With(scores, "armor", 9);
    let keysHaveArmor = collections::Contains(collections::Keys(updatedScores), "armor");
    let scoreCount: i32 = collections::Count(updatedScores) fit i32;

    let bonus: collections::Dictionary<string, i32> = {
        "shield": 5
    };

    let merged = collections::Merge(updatedScores, bonus);
    let mergedHasShield = collections::ContainsKey(merged, "shield");
    let trimmedScores = collections::Without(updatedScores, "mana");
    let trimmedCount: i32 = collections::Count(trimmedScores) fit i32;

    let ordered: collections::TreeMap<i32, i32> = {< 1: 10, 3: 30, 5: 50 >};
    let floorKey = collections::FloorKeyOr(ordered, 4, -1);
    let orderedCount: i32 = collections::Count(ordered) fit i32;

    console::Print($"Std collections surface: ${hasFour}/${first}/${slice.First()}/${collections::Count(extended) fit i32}/${collections::LastOr(filled, -1)}/${collections::FirstOr(sorted, -1)}/${collections::LastOr(sorted, -1)}/${joined}/${keysHaveArmor}/${scoreCount}/${mergedHasShield}/${trimmedCount}/${floorKey}/${orderedCount}");
    return 0;
}
